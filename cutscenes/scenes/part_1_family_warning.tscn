}, {
"args": ["Father:", "Ezzel, marami nang aksidente ng graduating students sa balita."],
"method": &"show_dialogue"
}, {
"args": ["Ezzel:", "Wag kayo mag alala tay, Mag iingat ako."],
"method": &"show_dialogue"
}, {
"args": ["Mother:", "Basta wag mo lang kalimutan bumili ka ng pandesal pag uwi mo ha."],
