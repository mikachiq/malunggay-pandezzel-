"transitions": PackedFloat32Array(1, 1, 1, 1, 1, 1, 1),
"values": [{
"args": ["System:", "“In every school… there is a story students don’t talk about.”"],
"method": &"show_dialogue"
}, {
"args": ["System:", "“A warning passed from batch to batch…especially to those who are about to finish.”"],
"method": &"show_dialogue"
}, {
"args": ["System:", "“They say… in your final days… something changes.”"],
"method": &"show_dialogue"
}, {
"args": ["System:", "“Small accidents. Strange delays. Unexplainable fear.”"],
"method": &"show_dialogue"
}, {
"args": ["System:", "“Not everyone notices it…”"],
"method": &"show_dialogue"
}, {
"args": ["System:", "“Until it’s too late.”"],
"method": &"show_dialogue"
}, {
"args": ["", ""],
"method": &"show_dialogue"
}]
}
